{
  "log": {
    "disabled": false,
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "cf",
        "type": "tls",
        "server": "1.1.1.1"
      },
      {
        "tag": "ali",
        "type": "tls",
        "server": "223.5.5.5"
      },
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "clash_mode": "Direct",
        "action": "route",
        "server": "ali"
      },
      {
        "clash_mode": "Global",
        "action": "route",
        "server": "fakeip"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "action": "route",
        "server": "fakeip",
        "rewrite_ttl": 1
      },
      {
        "rule_set": "cn_domain",
        "action": "route",
        "server": "ali"
      }
    ],
    "final": "cf",
    "strategy": "prefer_ipv4",
    "independent_cache": true
  },
  "inbounds": [
    {
      "tag": "tun-in",
      "type": "tun",
      "address": [
        "172.19.0.0/30",
        "fdfe:dcba:9876::0/126"
      ],
      "stack": "mixed",
      "auto_route": true,
      "strict_route": true,
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "127.0.0.1",
          "server_port": 7790
        }
      }
    },
    { "tag": "mixed-in",
      "type": "mixed",
      "listen": "127.0.0.1",
      "listen_port": 7790
    }
  ],
  "outbounds": [
    {
      "tag": "Proxy",
      "type": "selector",
      "interrupt_exist_connections": true,
      "outbounds": [
        "netcup",
        "hostdzire",
        "direct"
      ]
    },
    {
      "tag": "Google",
      "type": "selector",
      "interrupt_exist_connections": true,
      "outbounds": [
        "netcup",
        "hostdzire",
        "direct"
      ]
    },
    {
      "tag": "Github",
      "type": "selector",
      "interrupt_exist_connections": true,
      "outbounds": [
        "netcup",
        "hostdzire",
        "direct"
      ]
    },
    {
      "tag": "China",
      "type": "selector",
      "interrupt_exist_connections": true,
      "outbounds": [
        "netcup",
        "hostdzire",
        "direct"
      ]
    },
    {
      "tag": "netcup",
      "type": "selector",
      "outbounds": []
    },
    {
      "tag": "hostdzire",
      "type": "selector",
      "outbounds": []
    },
    {
      "type": "urltest",
      "tag": "all",
      "outbounds": [],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "30m",
      "tolerance": 50,
      "interrupt_exist_connections": true
    },
    {
      "tag": "direct",
      "type": "direct"
    }
  ],
  "route": {
    "default_domain_resolver": {
      "server": "ali"
    },
    "rules": [
      {
        "inbound": ["tun-in", "mixed-in"],
        "action": "sniff"
      },
      {
        "rule_set": "Advertising_domain",
        "action": "reject",
        "method": "default",
        "no_drop": false
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 53
          },
          {
            "protocol": "dns"
          }
        ],
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
      },
      {
        "clash_mode": "Global",
        "action": "route",
        "outbound": "Proxy"
      },
      {
        "clash_mode": "Direct",
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": "github_domain",
        "action": "route",
        "outbound": "Github"
      },
      {
        "rule_set": "google_domain",
        "action": "route",
        "outbound": "Google"
      },
      {
        "rule_set": "cn_domain",
        "action": "route",
        "outbound": "China"
      },
      {
        "rule_set": "proxy_domain",
        "action": "route",
        "outbound": "Proxy"
      },
      {
        "action": "resolve"
      },
      {
        "rule_set": "google_ip",
        "action": "route",
        "outbound": "Google"
      },
      {
        "rule_set": "cn_ip",
        "action": "route",
        "outbound": "China"
      }
    ],
    "final": "Proxy",
    "override_android_vpn": true,
    "auto_detect_interface": true,
    "rule_set": [
      {
        "tag": "cn_ip",
        "type": "remote",
        "format": "binary",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geoip/cn.srs",
        "download_detour": "direct"
      },
      {
        "tag": "cn_domain",
        "type": "remote",
        "format": "binary",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo-lite/geosite/cn.srs",
        "download_detour": "direct"
      },
      {
        "tag": "google_ip",
        "type": "remote",
        "format": "binary",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo-lite/geoip/google.srs",
        "download_detour": "direct"
      },
      {
        "tag": "google_domain",
        "type": "remote",
        "format": "binary",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo-lite/geosite/google.srs",
        "download_detour": "direct"
      },
      {
        "tag": "proxy_domain",
        "type": "remote",
        "format": "binary",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/geolocation-!cn.srs",
        "download_detour": "direct"
      },
      {
        "tag": "github_domain",
        "type": "remote",
        "format": "binary",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo-lite/geosite/github.srs",
        "download_detour": "direct"
      },
      {
        "tag": "Advertising_domain",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/senshinya/singbox_ruleset/main/rule/Advertising/Advertising.srs",
        "download_detour": "direct"
      }
    ]
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9091",
      "external_ui": "zashboard",
      "external_ui_download_url": "https://ghfast.top/https://github.com/Zephyruso/zashboard/archive/refs/heads/gh-pages.zip",
      "external_ui_download_detour": "direct"
    },
    "cache_file": {
      "enabled": true,
      "store_fakeip": true
    }
  }
}